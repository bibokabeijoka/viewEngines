<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title> App</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: linear-gradient(120deg, #4f46e5, #9333ea);
      color: white;
    }

    .navbar {
      display: flex;
      justify-content: space-between;
      padding: 20px;
      background: rgba(0,0,0,0.2);
    }

    .logo {
      margin: 0;
    }

    .navbar a {
      color: white;
      margin-left: 15px;
      text-decoration: none;
      font-weight: bold;
    }

    .hero {
      text-align: center;
      margin-top: 100px;
    }

    .btn {
      display: inline-block;
      margin-top: 20px;
      padding: 12px 25px;
      background: white;
      color: #4f46e5;
      border-radius: 25px;
      text-decoration: none;
      font-weight: bold;
      transition: 0.3s;
    }

    .btn:hover {
      background: #ddd;
    }

    footer {
      position: absolute;
      bottom: 10px;
      width: 100%;
      text-align: center;
      opacity: 0.8;
    }
  </style>
</head>

<body>
  <header class="navbar">
    <h1 class="logo">🚀 MinhaApp</h1>
    <nav>
      <a href="/">Início</a>
      <a href="/about">Sobre</a>
      <a href="/login">Login</a>
    </nav>
  </header>

  <main class="hero">
    <h2>Bem-vindo, {{user.nome}} 👋</h2>
    <p>{{mensagem}}</p>

    {{#if user.logado}}
      <a href="/dashboard" class="btn">Ir para Dashboard</a>
    {{else}}
      <a href="/register" class="btn">Criar Conta</a>
    {{/if}}
  </main>

  <footer>
    <p>© 2026 MinhaApp</p>
  </footer>
</body>
</html>

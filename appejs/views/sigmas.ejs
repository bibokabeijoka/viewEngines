<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <style>
    body { font-family: Arial; background: #ff96a8; color: #fff; padding: 20px; }
    nav a { color: white; margin-right: 10px; text-decoration: none; }
    .galeria img { width: 150px; border-radius: 10px; }
  </style>
</head>
<body>

  <nav>
    <a href="/">Home</a>
    <a href="/sigmas">Sigmas</a>
  </nav>

  <h1><%= title %></h1>
  <p><%= title %></p>

  <h2>title</h2>
  <ul>
    <% for(let i=0; i<eventos.length; i++) { %>
      <li><strong><%= eventos[i].ano %>:</strong> <%= eventos[i].texto %></li>
    <% } %>
  </ul>

  <h2>Galeria</h2>
  <div class="galeria">
    <div>
      <img src="https://upload.wikimedia.org/wikipedia/commons/2/2c/Vladimir_Lenin.jpg" alt="Lenin">
      <p>Lenin</p>
    </div>
    <div>
      <img src="https://upload.wikimedia.org/wikipedia/commons/3/3c/Joseph_Stalin.jpg" alt="Stalin">
      <p>Stalin</p>
    </div>
    <div>
      <img src="https://upload.wikimedia.org/wikipedia/commons/7/7c/Karl_Marx_001.jpg" alt="Marx">
      <p>Marx</p>
    </div>
    <div>
      <img src="https://upload.wikimedia.org/wikipedia/commons/4/4b/Friedrich_Engels_portrait.jpg" alt="Engels">
      <p>Engels</p>
    </div>
  </div>

  <footer>&copy; <%= ano %></footer>

</body>
</html>